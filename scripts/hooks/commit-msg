#!/bin/bash
# commit-msg hook (main branch only):
#   1. Validates conventional commit prefix
#   2. Computes VERSION bump + CHANGELOG entry
#      and writes params to .git/HOOK_DATA for post-commit to apply.

BRANCH=$(git rev-parse --abbrev-ref HEAD)
[ "$BRANCH" = "main" ] || exit 0

COMMIT_MSG_FILE="$1"
COMMIT_MSG=$(cat "$COMMIT_MSG_FILE")

# ‚îÄ‚îÄ 1. Validate conventional commit format ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ
PATTERN="^(feat|fix|refactor|style|docs|test|chore|ci|perf|build|revert)(\(.+\))?!?: .+"
if ! echo "$COMMIT_MSG" | grep -qE "$PATTERN"; then
    echo "ERROR: Commit message must follow Conventional Commits format."
    echo "  Format : <type>(<scope>): <description>"
    echo "  Example: feat(auth): add login page"
    echo "  Types  : feat | fix | refactor | style | docs | test | chore | ci | perf | build | revert"
    exit 1
fi

# ‚îÄ‚îÄ 2. Compute VERSION bump ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ
VERSION_FILE="VERSION"
VERSION=$(cat "$VERSION_FILE" | tr -d '[:space:]')

MAJOR=$(echo "$VERSION" | cut -d. -f1)
MINOR=$(echo "$VERSION" | cut -d. -f2)
PATCH=$(echo "$VERSION" | cut -d. -f3)

TYPE=$(echo "$COMMIT_MSG" | grep -oE "^[a-z]+")
IS_BREAKING=false
if echo "$COMMIT_MSG" | grep -qE "^[a-z]+(\([^)]+\))?!:"; then
    IS_BREAKING=true
elif echo "$COMMIT_MSG" | grep -q "BREAKING CHANGE"; then
    IS_BREAKING=true
fi

if [ "$IS_BREAKING" = true ]; then
    NEW_VERSION="$((MAJOR + 1)).0.0"
elif [ "$TYPE" = "feat" ]; then
    NEW_VERSION="${MAJOR}.$((MINOR + 1)).0"
else
    NEW_VERSION="${MAJOR}.${MINOR}.$((PATCH + 1))"
fi

# Only bump if already tagged; otherwise keep current version
if ! git tag --list | grep -qx "v$VERSION"; then
    NEW_VERSION="$VERSION"
fi

# ‚îÄ‚îÄ 3. Compute CHANGELOG section and description ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ
case "$TYPE" in
    feat)                SECTION="Added" ;;
    fix)                 SECTION="Fixed" ;;
    revert)              SECTION="Fixed" ;;
    refactor|style|perf) SECTION="Changed" ;;
    docs|chore|ci|build|test) SECTION="Changed" ;;
    *)                   SECTION="Changed" ;;
esac

# Use only the subject line (first line) as the description
DESCRIPTION=$(echo "$COMMIT_MSG" | head -1 | sed -E 's/^[a-z]+(\([^)]+\))?!?: //')

# ‚îÄ‚îÄ 4. Write params for post-commit ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ
printf 'NEW_VERSION=%s\nSECTION=%s\nDESCRIPTION=%s\n' \
    "$NEW_VERSION" "$SECTION" "$DESCRIPTION" > .git/HOOK_DATA
